# Root environment contract for Milestone 1 runtime topology.
# Ownership: platform/deployment.

# Public domain used by reverse-proxy metadata in production compose.
SFUS_PUBLIC_HOST=starfrontiers.us
LETSENCRYPT_EMAIL=ops@starfrontiers.us

# MySQL container settings for local/hybrid compose usage.
MYSQL_ROOT_PASSWORD=changeme-root
MYSQL_DATABASE=sfus
MYSQL_USER=sfus
MYSQL_PASSWORD=changeme-app

# Local API target used by host-run web rewrites in hybrid development.
LOCAL_API_ORIGIN=http://localhost:3001
