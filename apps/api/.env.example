# API app environment contract.
# Ownership: API application.

NODE_ENV=development
API_PORT=3001

# Swagger is enabled by default for local development and should remain disabled by default in production.
API_SWAGGER_ENABLED=true

# Auth and identity contract shared by local, OAuth identity-linking, session, and MFA flows.
AUTH_PASSWORD_PEPPER=changeme-auth-pepper
AUTH_SESSION_TOKEN_PEPPER=changeme-session-token-pepper
AUTH_SESSION_TTL_MINUTES=1440
AUTH_SESSION_IDLE_TIMEOUT_MINUTES=120
AUTH_EMAIL_VERIFICATION_TTL_MINUTES=60
AUTH_EXTERNAL_STATE_TTL_MINUTES=10
AUTH_TOTP_ISSUER=SFUS Development
AUTH_RECOVERY_CODE_COUNT=10
AUTH_RECOVERY_CODE_LENGTH=12
# These placeholders are sufficient to boot the local stack, but Google/GitHub sign-in
# requires real provider credentials and reachable callback URLs before those flows work.
AUTH_GOOGLE_CLIENT_ID=changeme-google-client-id
AUTH_GOOGLE_CLIENT_SECRET=changeme-google-client-secret
AUTH_GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/external/google/callback
AUTH_GITHUB_CLIENT_ID=changeme-github-client-id
AUTH_GITHUB_CLIENT_SECRET=changeme-github-client-secret
AUTH_GITHUB_CALLBACK_URL=http://localhost:3001/api/auth/external/github/callback

# Database contract used by the API process and the explicit migration service.
# Hybrid local development runs the API on the host against the Compose-managed
# MySQL port published on localhost. The full-stack Compose API service overrides
# these values to reach the internal `mysql` service on port 3306.
# Production values are host-managed outside the repo checkout and target an external MySQL 5.7.44 instance.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=sfus
DB_USER=sfus
DB_PASSWORD=changeme-app
DB_CONNECT_TIMEOUT_MS=5000
DB_MIGRATIONS_TABLE=sfus_migrations
