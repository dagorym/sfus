# Web app environment contract.
# Ownership: web application.

# Base API path consumed by the web app. Keep /api for proxy compatibility.
NEXT_PUBLIC_API_BASE_PATH=/api

# Host-run hybrid target when local rewrites forward /api requests.
WEB_API_ORIGIN=http://localhost:3001

# Internal service URL used by web container in full-stack compose.
WEB_API_INTERNAL_URL=http://api:3001
