{
  "name": "sfus-milestone-1",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "pnpm -r --filter \"./apps/*\" run build",
    "lint": "pnpm -r --filter \"./apps/*\" run lint",
    "typecheck": "pnpm -r --filter \"./apps/*\" run typecheck",
    "test": "pnpm -r --filter \"./apps/*\" run test",
    "format": "prettier --write \"apps/**/*.{ts,tsx,js,cjs,json,md}\" \"packages/**/*.{ts,tsx,js,cjs,json,md}\" package.json pnpm-workspace.yaml tsconfig.json README.md .eslintrc.cjs .prettierrc.cjs",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx,js,cjs,json,md}\" \"packages/**/*.{ts,tsx,js,cjs,json,md}\" package.json pnpm-workspace.yaml tsconfig.json README.md .eslintrc.cjs .prettierrc.cjs"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.1",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
